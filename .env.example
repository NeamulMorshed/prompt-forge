# Postgres
DATABASE_URL=postgresql+psycopg://promptforge:promptforge@localhost:5432/promptforge
# Redis
REDIS_URL=redis://localhost:6379/0
# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# LLM providers
GROQ_API_KEY=
# Additional LLM providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# CORS — comma-separated. Add your Vercel URL in production.
# e.g. CORS_ORIGINS=https://promptforge.vercel.app,https://promptforge.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Frontend (set in Vercel dashboard or apps/web/.env.local)
# NEXT_PUBLIC_API_BASE=https://your-api.up.railway.app
