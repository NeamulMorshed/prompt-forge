    { "id": "audience",   "weight": 0.15, "required": false, "hint": "Who is this for?" },
    { "id": "tone",       "weight": 0.12, "required": false, "hint": "What tone or style?" },
    { "id": "format",     "weight": 0.10, "required": false, "hint": "What output format do you need?" },
